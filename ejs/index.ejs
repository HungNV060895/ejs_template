<% 
  const services = [
	{ 
	  icon: "network", 
	  title: "ネットワーク設計・構築", 
	  desc: "最適なネットワーク環境を設計・構築します。" 
	},
	{ 
	  icon: "cloud", 
	  title: "クラウド・インテグレーション", 
	  desc: "クラウド導入から運用までをワンストップで支援します。" 
	},
	{ 
	  icon: "security", 
	  title: "セキュリティソリューション", 
	  desc: "多層的なセキュリティ対策でビジネスを守ります。" 
	},
	{ 
	  icon: "monitor", 
	  title: "運用・監視サービス", 
	  desc: "安定したシステム運用を24時間体制でサポートします。" 
	},
	{ 
	  icon: "support", 
	  title: "保守・サポートサービス", 
	  desc: "迅速な対応でシステムの安定稼働を支えます。" 
	},
	{ 
	  icon: "consulting", 
	  title: "ITコンサルティング", 
	  desc: "お客様の課題を分析し、最適なIT戦略をご提案します。" 
	}
  ];

  const strengths = [
	{ 
	  icon: "experience", 
	  title: "豊富な実績とノウハウ", 
	  desc: "幅広い業種・業界での導入実績と培ってきたノウハウで、最適なソリューションを提供します。" 
	},
	{ 
	  icon: "onestop", 
	  title: "ワンストップ対応", 
	  desc: "設計・構築から運用・保守までワンストップで対応できるため、安心してお任せいただけます。" 
	},
	{ 
	  icon: "support247", 
	  title: "24時間365日サポート", 
	  desc: "24時間365日体制で、サポート対応。システムの安定稼働をしっかりと支えます。" 
	},
	{ 
	  icon: "partnership", 
	  title: "パートナーシップ", 
	  desc: "お客様のビジネスパートナーとして、長期的な視点で成長をサポートします。" 
	}
  ];

  const cases = [
	{ 
	  img: "case1.jpg", 
	  badge: "製造業", 
	  title: "グローバルネットワーク基盤の刷新", 
	  desc: "グローバル拠点間のネットワークを刷新し、通信品質の向上とコスト削減を実現。" 
	},
	{ 
	  img: "case2.jpg", 
	  badge: "金融業", 
	  title: "セキュアなクラウド基盤の構築", 
	  desc: "高いセキュリティ要件を満たすクラウド基盤を構築し、業務効率化 và BCP強化を実現。" 
	},
	{ 
	  img: "case3.jpg", 
	  badge: "官公庁・自治体", 
	  title: "自治体情報システムの運用支援", 
	  desc: "システムの安定運用 và 住民サービスの向上を支える運用・保守体制を提供。" 
	}
  ];

  const newsList = [
	{ 
	  date: "2024.05.24", 
	  type: "notice", 
	  badge: "お知らせ", 
	  title: "コーポレートサイトをリニューアルしました" 
	},
	{ 
	  date: "2024.04.10", 
	  type: "press", 
	  badge: "プレスリリース", 
	  title: "クラウドインテグレーションサービスを強化" 
	},
	{ 
	  date: "2024.03.01", 
	  type: "notice", 
	  badge: "お知らせ", 
	  title: "「健康経営優良法人2024」に認定されました" 
	},
	{ 
	  date: "2024.02.15", 
	  type: "seminar", 
	  badge: "セミナー", 
	  title: "オンラインセミナー「ゼロトラストセキュリティの最前線」を開催" 
	}
  ];
%>
		<section class="hero">
			<div class="hero__bg"></div>
			<div class="hero__container">
				<h1 class="hero__title">テクノロジーで、<br>未来のインフラを支える。</h1>
				<p class="hero__desc">シンオン株式会社は、ネットワーク・インフラ構築から<br>運用・保守までをワンストップで提供する<br>ICTソリューションカンパニーです。</p>
				<div class="hero__buttons">
					<a href="#" class="btn btn--primary">サービスを見る <i class="icon-arrow-right"></i></a>
					<a href="#" class="btn btn--outline">お問い合わせ <i class="icon-arrow-right"></i></a>
				</div>
			</div>
		</section>

		<div class="ticker">
			<div class="ticker__container">
				<span class="ticker__badge">お知らせ</span>
				<span class="ticker__date">2024.05.24</span>
				<span class="ticker__text">コーポレートサイトをリニューアルしました</span>
				<a href="#" class="ticker__link">一覧を見る <i class="icon-arrow-right"></i></a>
			</div>
		</div>

		<section class="section services">
			<div class="section__container">
				<h2 class="section__title">提供サービス</h2>
				<p class="section__subtitle">設計・構築から運用・保守まで、<br>お客様の課題に合わせた最適なソリューションを提供します。</p>

				<div class="services__grid">
					<% services.forEach(function(service) { %>
						<a href="#" class="service-card">
							<div class="service-card__icon-wrapper">
								<img src="/assets/icons/<%= service.icon %>.svg" alt="" class="service-card__icon">
							</div>
							<h3 class="service-card__title">
								<%= service.title %>
							</h3>
							<p class="service-card__desc">
								<%= service.desc %>
							</p>
							<i class="service-card__arrow icon-arrow-right"></i>
						</a>
						<% }); %>
				</div>

				<div class="section__action">
					<a href="#" class="btn btn--outline">すべてのサービスを見る <i class="icon-arrow-right"></i></a>
				</div>
			</div>
		</section>

		<section class="section strengths">
			<div class="section__container">
				<h2 class="section__title">シンオンの強み</h2>

				<div class="strengths__grid">
					<% strengths.forEach(function(strength) { %>
						<div class="strength-card">
							<div class="strength-card__icon-wrapper">
								<img src="/assets/icons/<%= strength.icon %>.svg" alt="" class="strength-card__icon">
							</div>
							<div class="strength-card__content">
								<h3 class="strength-card__title">
									<%= strength.title %>
								</h3>
								<p class="strength-card__desc">
									<%= strength.desc %>
								</p>
							</div>
						</div>
						<% }); %>
				</div>
			</div>
		</section>

		<section class="section cases">
			<div class="section__container">
				<div class="section__header">
					<h2 class="section__title section__title--left">導入事例</h2>
					<a href="#" class="section__link">すべての導入事例を見る <i class="icon-arrow-right"></i></a>
				</div>

				<div class="cases__grid">
					<% cases.forEach(function(item) { %>
						<a href="#" class="case-card">
							<div class="case-card__img-wrapper">
								<img src="/assets/images/<%= item.img %>" alt="" class="case-card__img">
								<span class="case-card__badge">
									<%= item.badge %>
								</span>
							</div>
							<div class="case-card__content">
								<h3 class="case-card__title">
									<%= item.title %>
								</h3>
								<p class="case-card__desc">
									<%= item.desc %>
								</p>
								<span class="case-card__link">詳しく見る <i class="icon-arrow-right"></i></span>
							</div>
						</a>
						<% }); %>
				</div>
			</div>
		</section>

		<section class="section news">
			<div class="section__container">
				<div class="section__header">
					<h2 class="section__title section__title--left">ニュース</h2>
					<a href="#" class="section__link">一覧を見る <i class="icon-arrow-right"></i></a>
				</div>

				<ul class="news__list">
					<% newsList.forEach(function(news) { %>
						<li class="news__item">
							<a href="#" class="news-card">
								<div class="news-card__meta">
									<span class="news-card__date">
										<%= news.date %>
									</span>
									<span class="news-card__badge news-card__badge--<%= news.type %>">
										<%= news.badge %>
									</span>
								</div>
								<h3 class="news-card__title">
									<%= news.title %>
								</h3>
								<i class="news-card__arrow icon-arrow-right"></i>
							</a>
						</li>
						<% }); %>
				</ul>
			</div>
		</section>

		<div class="cta-banner">
			<div class="cta-banner__container">
				<div class="cta-banner__content">
					<div class="cta-banner__icon-wrapper">
						<i class="icon-mail-large"></i>
					</div>
					<div class="cta-banner__text">
						<h2 class="cta-banner__title">ご不明点やご相談など、お気軽にお問い合わせください。</h2>
						<p class="cta-banner__desc">専門スタッフが丁寧にご対応いたします。</p>
					</div>
				</div>
				<a href="#" class="btn btn--white">お問い合わせフォームへ <i class="icon-arrow-right"></i></a>
			</div>
		</div>